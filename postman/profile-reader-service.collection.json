{
  "info": {
    "name": "profile-reader-service",
    "description": "Public-facing read cache in front of profile pages. Reads come from Redis first and fall back to profile-service on a miss.\n\n## Setup\n1. Import this collection and the `waypoint-bio.environment.json` environment.\n2. Select the environment (top-right) and make sure `reader_service_url` and `profile_public_username` are set.\n3. Run requests in order, or use the Collection Runner.\n\n## Endpoints\n- `GET /health` — liveness, always 200.\n- `GET /{username}` — public profile (cache -> upstream). Sets `X-Cache: HIT|MISS`.\n- `DELETE /cache/{username}` — invalidate a cached profile (204).\n\nThe `Get Profile (warm cache)` request can be run right after `Get Profile (cold)` to confirm an `X-Cache: HIT`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "reader_service_url",
      "value": "http://localhost:3020",
      "type": "string"
    },
    {
      "key": "profile_public_username",
      "value": "testuser",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{reader_service_url}}/health",
          "host": ["{{reader_service_url}}"],
          "path": ["health"]
        },
        "description": "Liveness only — no dependency checks, always returns 200 {\"status\":\"ok\"}."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('body is ok', () => {",
              "  pm.expect(pm.response.json()).to.have.property('status', 'ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Profile (cold / cache MISS)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Forwarded-For",
            "value": "203.0.113.10",
            "description": "First hop is used as the client IP for the analytics view event."
          }
        ],
        "url": {
          "raw": "{{reader_service_url}}/{{profile_public_username}}",
          "host": ["{{reader_service_url}}"],
          "path": ["{{profile_public_username}}"]
        },
        "description": "Fetch a public profile. On a cache miss this calls profile-service, stores the result in Redis, returns X-Cache: MISS, and fires a non-blocking analytics view event.\n\nRun `Invalidate Cache` first if you want to guarantee a MISS."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('has X-Cache header', () => {",
              "  pm.expect(pm.response.headers.get('X-Cache')).to.be.oneOf(['HIT', 'MISS']);",
              "});",
              "pm.test('returns the requested profile', () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('username', pm.variables.get('profile_public_username'));",
              "  pm.expect(body).to.have.property('links');",
              "  pm.expect(body.links).to.be.an('array');",
              "});",
              "console.log('X-Cache:', pm.response.headers.get('X-Cache'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Profile (warm / cache HIT)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{reader_service_url}}/{{profile_public_username}}",
          "host": ["{{reader_service_url}}"],
          "path": ["{{profile_public_username}}"]
        },
        "description": "Run this immediately after the cold request. Within the cache TTL it should return X-Cache: HIT directly from Redis."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('served from cache (X-Cache: HIT)', () => {",
              "  pm.expect(pm.response.headers.get('X-Cache')).to.eql('HIT');",
              "});",
              "pm.test('returns the requested profile', () => {",
              "  pm.expect(pm.response.json()).to.have.property('username', pm.variables.get('profile_public_username'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Profile (not found)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{reader_service_url}}/this-user-does-not-exist-9999",
          "host": ["{{reader_service_url}}"],
          "path": ["this-user-does-not-exist-9999"]
        },
        "description": "profile-service returns 404 -> reader returns 404 and does not cache."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 404', () => pm.response.to.have.status(404));",
              "pm.test('error body', () => {",
              "  pm.expect(pm.response.json()).to.have.property('error');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Invalidate Cache",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{reader_service_url}}/cache/{{profile_public_username}}",
          "host": ["{{reader_service_url}}"],
          "path": ["cache", "{{profile_public_username}}"]
        },
        "description": "Drop the Redis key for a username. profile-service calls this (best-effort) after any profile or link write. Returns 204. Idempotent — succeeds even if the key was absent."
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 204', () => pm.response.to.have.status(204));",
              "pm.test('no body', () => {",
              "  pm.expect(pm.response.text()).to.eql('');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
